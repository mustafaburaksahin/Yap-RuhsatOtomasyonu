<Page x:Class="YapıRuhsatOtomasyonu.KullaniciBilgileri.KullanicilarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="1050" d:DesignWidth="1300" 
      Background="White" Title="Kullanıcılar">

    <Grid Margin="0" x:Name="Panel1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <GroupBox Grid.Column="0" Header="Kullanıcı Detayları" Background="#F5F5F5" Margin="0,0,10,0" BorderBrush="#D0D0D0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="135"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Burada StackPanel kodu sayesinde Panel1 kısmına name verebildik -->
                            <TextBlock Grid.Row="0" Text="ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="1" Text="Aktif:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <CheckBox x:Name="chkAktifMi" Grid.Row="1" Grid.Column="1" Content="Evet" Margin="0,0,0,8" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Text="TC Kimlik No:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtTcKimlikNo" Grid.Row="2" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="3" Text="Adı Soyadı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtAdSoyad" Grid.Row="3" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="4" Text="Doğum Yeri:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtDogumYeri" Grid.Row="4" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="5" Text="Doğum Tarihi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <DatePicker x:Name="dpDogumTarihi" Grid.Row="5" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="6" Text="Anne Adı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtAnneAdi" Grid.Row="6" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="7" Text="Baba Adı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtBabaAdi" Grid.Row="7" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="8" Text="Telefon No:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtTelefonNo" Grid.Row="8" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="9" Text="GSM No:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtGsmNo" Grid.Row="9" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="10" Text="Email:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtEmail" Grid.Row="10" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="11" Text="Kullanıcı Adı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtKullaniciAdi" Grid.Row="11" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="12" Text="Şifre:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtSifre" Grid.Row="12" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="13" Text="Kullanıcı Tipi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <ComboBox x:Name="cmbKullaniciTipi" Grid.Row="13" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="14" Text="Ünvan:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <ComboBox x:Name="cmbUnvan" Grid.Row="14" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="15" Text="Birim:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <ComboBox x:Name="cmbBirim" Grid.Row="15" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="16" Text="Tanım:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtTanim" Grid.Row="16" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="17" Text="Adres:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,8"/>
                            <TextBox x:Name="txtAdres" Grid.Row="17" Grid.Column="1" Height="50" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="18" Text="Diğer Bilgiler:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,8"/>
                            <TextBox x:Name="txtDigerBilgiler" Grid.Row="18" Grid.Column="1" Height="50" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="19" Text="Açıklama:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,15"/>
                            <TextBox x:Name="txtAciklama" Grid.Row="19" Grid.Column="1" Height="50" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" Padding="5"/>

                            <TextBlock Grid.Row="20" Text="Kaydeden Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtKaydeden" Grid.Row="20" Grid.Column="1" IsReadOnly="True" Background="#F5F5F5" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="21" Text="Kayıt Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtKayitTarihi" Grid.Row="21" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="22" Text="Değiştiren Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                            <TextBox x:Name="txtDegistiren" Grid.Row="22" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                            <TextBlock Grid.Row="23" Text="Değiştirilme Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistirmeTarihi" Grid.Row="23" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>
                </Grid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Kullanıcılar" BorderBrush="#D0D0D0" Margin="0">
            <Grid>
                <DataGrid x:Name="dgKullanicilar"
          SelectionChanged="dgKullanicilar_SelectionChanged"
          AutoGenerateColumns="False" 
          IsReadOnly="True" 
          CanUserAddRows="False"
          CanUserReorderColumns="False" 
          CanUserResizeColumns="True"
          Background="White" 
          AlternatingRowBackground="#FAFAFA"
          GridLinesVisibility="All" 
          HorizontalGridLinesBrush="#E0E0E0" 
          VerticalGridLinesBrush="#E0E0E0"
          RowHeight="35" 
          ColumnWidth="Auto" 
          MinColumnWidth="90" 
          HorizontalScrollBarVisibility="Visible" 
          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <!-- ID Filtresi -->
                        <DataGridTextColumn Binding="{Binding SiraNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="ID" FontWeight="Bold"/>
                                        <TextBox Width="60" TextChanged="FilterTextBox_TextChanged" Tag="SiraNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Aktif/Pasif Filtresi (ComboBox) -->
                        <DataGridCheckBoxColumn Binding="{Binding AktifMi}">
                            <DataGridCheckBoxColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Aktif" FontWeight="Bold"/>
                                        <ComboBox Width="70" SelectionChanged="FilterComboBox_SelectionChanged" Tag="AktifMi">
                                            <ComboBoxItem Content="Tümü" IsSelected="True"/>
                                            <ComboBoxItem Content="Aktif"/>
                                            <ComboBoxItem Content="Pasif"/>
                                        </ComboBox>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridCheckBoxColumn.HeaderTemplate>
                        </DataGridCheckBoxColumn>

                        <!-- TC Kimlik No -->
                        <DataGridTextColumn Binding="{Binding TcKimlikNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="TC Kimlik No" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="TcKimlikNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Ad Soyad -->
                        <DataGridTextColumn Binding="{Binding AdSoyad}" Width="150">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Ad Soyad" FontWeight="Bold"/>
                                        <TextBox Width="120" TextChanged="FilterTextBox_TextChanged" Tag="AdSoyad" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Doğum Yeri -->
                        <DataGridTextColumn Binding="{Binding DogumYeri}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Doğum Yeri" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="DogumYeri" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Diğer Metin Sütunları İçin Aynı Şablon -->
                        <!-- Anne Adı -->
                        <DataGridTextColumn Binding="{Binding AnneAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Anne Adı" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="AnneAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Baba Adı -->
                        <DataGridTextColumn Binding="{Binding BabaAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Baba Adı" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="BabaAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Telefon NO -->
                        <DataGridTextColumn Binding="{Binding TelefonNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Telefon NO" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="TelefonNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- GSM No -->
                        <DataGridTextColumn Binding="{Binding GsmNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="GSM No" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="GsmNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Kullanıcı Adı -->
                        <DataGridTextColumn Binding="{Binding KullaniciAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Kullanıcı Adı" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="KullaniciAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Ünvan (Navigation Property içerdiği için Tag="Unvan.UnvanAdi") -->
                        <DataGridTextColumn Binding="{Binding Unvan.UnvanAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Ünvan" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="Unvan.UnvanAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <!-- Birim -->
                        <DataGridTextColumn Binding="{Binding Birim.BirimAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Birim" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="Birim.BirimAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</Page>