<Page x:Class="YapıRuhsatOtomasyonu.KullaniciBilgileri.UnvanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Ünvan Tanımlama" d:DesignHeight="850" d:DesignWidth="1300"
      xmlns:d="http://schemas.expression.blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d" Background="#F0F0F0">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox x:Name="Panel1" Grid.Column="0" Width="420" Header="Ünvan Detayları" BorderBrush="#D0D0D0" Margin="0,0,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="135"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="1" Text="Ünvan:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtUnvan" Grid.Row="1" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="2" Text="Diğer Bilgiler:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDigerBilgiler" Grid.Row="2" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="3" Text="Açıklama:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,15"/>
                    <TextBox x:Name="txtAciklama" Grid.Row="3" Grid.Column="1" Height="80" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Grid.Row="4" Text="Kaydeden Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtKaydeden" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="5" Text="Kayıt Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtKayitTarihi" Grid.Row="5" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>
                    
                    <TextBlock Grid.Row="6" Text="Değiştiren Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistiren" Grid.Row="6" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="7" Text="Değiştirme Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistirmeTarihi" Grid.Row="7" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                </Grid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Ünvanlar Listesi" BorderBrush="#D0D0D0" Margin="0">
            <DataGrid x:Name="dgUnvanlar" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      CanUserAddRows="False"
                      CanUserReorderColumns="False" 
                      CanUserResizeColumns="True"
                      Background="White" 
                      AlternatingRowBackground="#FAFAFA" 
                      SelectionChanged="dgUnvanlar_SelectionChanged"
                      GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#E0E0E0" 
                      VerticalGridLinesBrush="#E0E0E0"
                      RowHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding SiraNo}" Width="60"/>
                    <DataGridTextColumn Header="Ünvan" Binding="{Binding UnvanAdi}" Width="2*"/>
                    <DataGridTextColumn Header="Diğer Bilgiler" Binding="{Binding DigerBilgiler}" Width="*"/>
                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Page>