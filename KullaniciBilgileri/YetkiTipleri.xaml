<Page x:Class="YapıRuhsatOtomasyonu.KullaniciBilgileri.YetkiTipleriPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" d:DesignHeight="850" d:DesignWidth="1300"
      Title="Yetki Tipi Tanımlama" Background="#F0F0F0">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL 1: YETKİ TİPİ DETAYLARI -->
        <GroupBox Grid.Column="0" Header="Yetki Tipi Detayları" BorderBrush="#D0D0D0" Margin="0,0,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="135"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="1" Text="Yetki Tipi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtYetkiTipi" Grid.Row="1" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="2" Text="Diğer Bilgiler:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,8"/>
                    <TextBox x:Name="txtDigerBilgiler" Grid.Row="2" Grid.Column="1" Height="80" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="3" Text="Açıklama:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,15"/>
                    <TextBox x:Name="txtAciklama" Grid.Row="3" Grid.Column="1" Height="80" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Grid.Row="4" Text="Kaydeden Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <ComboBox x:Name="cmbKaydeden" Grid.Row="4" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="5" Text="Kayıt Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtKayitTarihi" Grid.Row="5" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="6" Text="Değiştiren Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <ComboBox x:Name="cmbDegistiren" Grid.Row="6" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="7" Text="Değiştirme Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistirmeTarihi" Grid.Row="7" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Padding="5" Margin="0,0,0,8"/>
                </Grid>
            </ScrollViewer>
        </GroupBox>

        <!-- PANEL 2: YETKİ TİPLERİ TABLOSU -->
        <GroupBox Grid.Column="1" Header="Yetki Tipleri Listesi" BorderBrush="#D0D0D0" Margin="0">
            <DataGrid x:Name="dgYetkiTipleri" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      Background="White" AlternatingRowBackground="#FAFAFA" SelectionChanged="dgYetkiTipleri_SelectionChanged"
                      GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                      RowHeight="35">
                <DataGrid.Columns>
                    <!-- BİNDİNG GÜNCELLENDİ: Id yerine SiraNo kullanıldı -->
                    <DataGridTextColumn Header="ID" Binding="{Binding SiraNo}" Width="Auto" MinWidth="50"/>
                    <DataGridTextColumn Header="Yetki Tipi" Binding="{Binding YetkiTipiAdi}" Width="2*"/>
                    <DataGridTextColumn Header="Diğer Bilgiler" Binding="{Binding DigerBilgiler}" Width="*"/>
                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Page>