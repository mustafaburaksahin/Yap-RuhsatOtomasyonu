<Window x:Class="YapiRuhsatOtomasyonu.Pages.DosyaDetay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Dosya Detayları" Height="680" Width="680"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Border Background="#FFFFFF" 
                CornerRadius="4" 
                BorderBrush="#707070" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="2" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#EEEEEE" Padding="8,5" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Click="BtnKaydet_Click" Style="{StaticResource MaterialDesignRaisedButton}" 
                                Background="#2E7D32" BorderBrush="#1B5E20" Height="32" Width="100" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="KAYDET" Margin="5,0,0,0" FontSize="11" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        <Button Click="BtnKapat_Click" Style="{StaticResource MaterialDesignRaisedButton}" 
                                Background="#D32F2F" BorderBrush="#B71C1C" Height="32" Width="100">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="KAPAT" Margin="5,0,0,0" FontSize="11" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#3F51B5" Padding="20,10">
                    <TextBlock Text="DOSYA BİLGİLERİ DÜZENLEME" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Left"/>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <Grid Grid.IsSharedSizeScope="True">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#222222"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,15,20"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>

                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                    <Setter Property="Margin" Value="0,0,0,20"/>
                                    <Setter Property="Foreground" Value="#222222"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#888888"/>
                                </Style>

                                <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                    <Setter Property="Margin" Value="0,0,0,20"/>
                                    <Setter Property="Foreground" Value="#222222"/>
                                    <Setter Property="BorderBrush" Value="#888888"/>
                                </Style>
                            </Grid.Resources>

                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Seçilen Konum:"/>
                                    <TextBox Grid.Column="1" x:Name="txtDosyaKonumu" IsReadOnly="True" Background="#F5F5F5"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Kayıt ID:"/>
                                    <TextBox Grid.Column="1" x:Name="txtId" IsReadOnly="True" FontWeight="Bold" Foreground="#1A237E" Background="#F5F5F5"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Yapı Sahibi:"/>
                                    <TextBox Grid.Column="1" x:Name="txtYapiSahibi" IsReadOnly="True" Background="#F5F5F5"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Dosya Tipi:"/>
                                    <ComboBox Grid.Column="1" x:Name="cmbDosyaTipi"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Dosya Adı:"/>
                                    <TextBox Grid.Column="1" x:Name="txtDosyaYolu" IsReadOnly="True" Background="#F5F5F5"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Açıklama:" VerticalAlignment="Top" Margin="0,10,15,0"/>
                                    <TextBox Grid.Column="1" x:Name="txtAciklama" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                                             VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Margin="0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>