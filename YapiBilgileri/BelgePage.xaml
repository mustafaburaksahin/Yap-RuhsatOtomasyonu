<Page x:Class="YapıRuhsatOtomasyonu.YapiBilgileri.BelgePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Belge Tipleri" d:DesignHeight="700" d:DesignWidth="1200" Background="#F0F0F0">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox x:Name="Panel1" 
                  Grid.Column="0" 
                  Width="420"
                  Header="Belge Tip Detayları" 
                  Background="#F0F0F0" 
                  Margin="0,0,10,0" 
                  BorderBrush="#C0C0C0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="ID:" VerticalAlignment="Center" Margin="0,0,8,10" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Grid.Row="1" Text="Belge Tipi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtBelgeTipi" Grid.Row="1" Grid.Column="1" Background="White" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Text="Diğer Bilgiler:" VerticalAlignment="Top" Margin="0,5,8,10" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtDigerBilgiler" Grid.Row="2" Grid.Column="1" Height="80" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Grid.Row="3" Text="Açıklama:" VerticalAlignment="Top" Margin="0,5,8,10" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtAciklama" Grid.Row="3" Grid.Column="1" Height="80" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Grid.Row="4" Text="Kaydeden Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtKaydeden" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="5" Text="Kaydedilen Tarih:" VerticalAlignment="Center" Margin="0,0,8,10" HorizontalAlignment="Right" Foreground="Gray"/>
                    <TextBox x:Name="txtKayitTarihi" Grid.Row="5" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Grid.Row="6" Text="Değiştiren Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistiren" Grid.Row="6" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="7" Text="Değiştirme Tarihi:" VerticalAlignment="Center" Margin="0,0,8,10" HorizontalAlignment="Right" Foreground="Gray"/>
                    <TextBox x:Name="txtDegistirmeTarihi" Grid.Row="7" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,10" Padding="5"/>

                </Grid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Belge Tipleri" BorderBrush="#C0C0C0" Margin="0">
            <DataGrid x:Name="dgBelgeTipleri" 
                      SelectionChanged="dgBelgeTipleri_SelectionChanged"
                      CanUserSortColumns="False"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      CanUserAddRows="False"
                      CanUserReorderColumns="False"
                      Background="White" 
                      AlternatingRowBackground="#F9F9F9"
                      GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#E0E0E0" 
                      VerticalGridLinesBrush="#E0E0E0"
                      RowHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding SiraNo}" Width="60"/>
                    <DataGridTextColumn Header="Belge Tipleri" Binding="{Binding Ad}" Width="2*"/>
                    <DataGridTextColumn Header="Diğer Bilgiler" Binding="{Binding DigerBilgiler}" Width="3*"/>
                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Page>