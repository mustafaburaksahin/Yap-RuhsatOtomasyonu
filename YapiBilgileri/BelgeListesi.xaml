<Window x:Class="YapıRuhsatOtomasyonu.Pages.BelgeListesi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        x:Name="BelgeWindow" 
        Title="Yapıya Ait Belgeler" Height="500" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,15" VerticalAlignment="Center">
            <TextBlock Text="Yapıya Ait Belgeler" FontSize="22" FontWeight="Bold" Foreground="#F57C00"/>
            <TextBlock x:Name="txtYapiId" Text=" - Yapının ID : " FontSize="22" FontWeight="Bold" Foreground="#F57C00" Margin="5,0,0,0"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1" materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <DataGrid x:Name="dgBelgeListesi"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" 
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      Background="White"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ruhsat Veriliş Amacı" Binding="{Binding RuhsatAmaci.VerilisAmaci}" Width="1.2*"/>
                    <DataGridTextColumn Header="Ruhsat No" Binding="{Binding RuhsatNo}" Width="*"/>
                    <DataGridTextColumn Header="Ruhsat Tarihi" Binding="{Binding RuhsatTarihi}" Width="*"/>
                    <DataGridTextColumn Header="İskan Tarihi" Binding="{Binding IskanTarihi}" Width="*"/>
                    <DataGridTextColumn Header="İskan Amacı" Binding="{Binding IskanAmaci.VerilisAmaci}" Width="*"/>
                    <DataGridTextColumn Header="Esas Ruhsat" Binding="{Binding BelgeyeEsasRuhsat}" Width="*"/>
                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="1.5*"/>
                    <DataGridTextColumn Header="Belge Adı" Binding="{Binding BelgeAdi}" Width="1.2*"/>
                    <DataGridTextColumn Header="Kayıt Tarihi" Binding="{Binding KayitTarihi}" Width="*"/>

                    <DataGridTemplateColumn Header="İşlemler" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="GÖRÜNTÜLE" 
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Click="BtnDosyaAc_Click" 
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Foreground="#1565C0"
                                            Margin="0,0,5,0"/>

                                    <Button Content="SİL" 
                                            FontSize="10" 
                                            FontWeight="Bold" 
                                            Foreground="Red" 
                                            Click="BtnBelgeSil_Click" 
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Visibility="{Binding AdminVisibility, ElementName=BelgeWindow}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</Window>