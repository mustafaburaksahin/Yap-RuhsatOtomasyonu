<Page x:Class="YapıRuhsatOtomasyonu.YapiBilgileri.PDF"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="PDF" Background="#F5F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Zoom Butonları için üst alan -->
            <RowDefinition Height="Auto"/>
            <!-- PDF İçeriği için kalan alan -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ZOOM ARAÇ ÇUBUĞU -->
        <materialDesign:Card Grid.Row="0" Margin="10,10,10,0" UniformCornerRadius="8" Padding="5" Background="White" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Click="BtnZoomOut_Click" Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Uzaklaştır">
                    <materialDesign:PackIcon Kind="MagnifyMinus" Width="24" Height="24" Foreground="#2C3E50"/>
                </Button>

                <TextBlock x:Name="txtZoomLevel" Text="%100" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="10,0" Width="40" TextAlignment="Center"/>

                <Button Click="BtnZoomIn_Click" Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Yakınlaştır">
                    <materialDesign:PackIcon Kind="MagnifyPlus" Width="24" Height="24" Foreground="#2C3E50"/>
                </Button>

                <Button Click="BtnZoomReset_Click" Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Sıfırla" Margin="10,0,0,0">
                    <materialDesign:PackIcon Kind="Restore" Width="24" Height="24" Foreground="#E74C3C"/>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <!-- KAYDIRILABİLİR PDF İÇERİK ALANI -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="10">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="pdfScaleTransform" ScaleX="1" ScaleY="1"/>
                </Grid.LayoutTransform>

                <Viewbox Stretch="Uniform">
                    <!-- A4 Yatay Form Çerçevesi (Kalın Dış Hat) -->
                    <Border Width="1120" Height="1415" BorderBrush="Black" BorderThickness="3" Padding="3" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Başlık -->
                                <RowDefinition Height="Auto"/>
                                <!-- Panel 1 & 2 -->
                                <RowDefinition Height="Auto"/>
                                <!-- Panel 3, 4, 5 -->
                                <RowDefinition Height="Auto"/>
                                <!-- Panel 6 & 7 -->
                                <RowDefinition Height="Auto"/>
                                <!-- Panel 8 -->
                                <RowDefinition Height="*"/>
                                <!-- Panel 9 ve Kalan Boşluk -->
                            </Grid.RowDefinitions>

                            <!-- ================= BAŞLIK VE BARKOD ALANI ================= -->
                            <Border Grid.Row="0" BorderBrush="Black" BorderThickness="2" Background="Blue" Padding="5" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 1. SOL: KURUM LOGOSU -->
                                    <Image x:Name="imgKurumLogo" Grid.Column="0" Width="70" Height="70" HorizontalAlignment="Left" Margin="10,0,0,0" Stretch="Uniform"/>

                                    <!-- 2. ORTA: YAZI -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="YAPI RUHSATI" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Building Licence" FontSize="14" FontStyle="Italic" Foreground="White" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- 3. SAĞ: BARKOD -->
                                    <Border Grid.Column="2" BorderBrush="White" BorderThickness="1" Background="White" Width="110" Height="60" HorizontalAlignment="Right" Margin="0,0,5,0">
                                        <TextBlock Text="Barkod/Karekod" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ================= PANEL 1 & PANEL 2 ================= -->
                            <Grid Grid.Row="1" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <!-- PANEL 1 -->
                                <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2,2,1,2" Padding="4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <!-- Ruhsat Veren Kurum -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Ayırıcı Çizgi -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Adres Başlığı -->
                                            <RowDefinition Height="*"/>
                                            <!-- Adres Formu -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Alt Tablo -->
                                        </Grid.RowDefinitions>

                                        <!-- 1. Bölüm: Ruhsat Veren Kurum -->
                                        <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                            <TextBlock Text="1. Ruhsat veren kurum" FontSize="8" FontWeight="Bold" Foreground="#000080"/>
                                            <TextBlock x:Name="txtRuhsatVerenKurum" Text="................................................................................................................................................................................................................................................................" FontSize="8" Margin="0,2,0,2"/>
                                        </StackPanel>

                                        <!-- Araya İnce Ayırıcı Çizgi -->
                                        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="0,1,0,0" Margin="0,5,0,5"/>

                                        <!-- 2. Bölüm Başlığı -->
                                        <TextBlock Grid.Row="2" Text="2. Ruhsat verilen yapının adresi" FontSize="8" FontWeight="Bold" Margin="0,0,0,5" Foreground="#000080"/>

                                        <!-- ADRES HİZALAMA IZGARASI (Ferahlatılmış ve Hizalanmış) -->
                                        <Grid Grid.Row="3" Margin="0,5,0,15" ClipToBounds="True">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Satır 1: İl / İlçe -->
                                            <Grid Grid.Row="0" Margin="0,10,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="İl: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1" Margin="2,0,10,0" VerticalAlignment="Center">
                                                    <TextBlock Text=".................................................................................." FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtIl}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Kullanıcı dokunamasın diye IsReadOnly, Focusable ve Cursor özellikleri eklendi -->
                                                    <TextBox x:Name="txtIl" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center" IsReadOnly="True" Focusable="False" Cursor="Arrow"/>
                                                </Grid>

                                                <TextBlock Grid.Column="2" Text="İlçe: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="3" Margin="2,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text=".................................................................................." FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtIlce}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Kullanıcı dokunamasın diye IsReadOnly, Focusable ve Cursor özellikleri eklendi -->
                                                    <TextBox x:Name="txtIlce" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center" IsReadOnly="True" Focusable="False" Cursor="Arrow"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Satır 2: Köy -->
                                            <Grid Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Köy: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1" Margin="2,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="................................................................................................................................................................................................................................" FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtKoy}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtKoy" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Satır 3: Mahalle / Mahalle Tanıtım Kodu -->
                                            <Grid Grid.Row="2" Margin="0,12,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Mahalle/Mevki: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1" Margin="2,0,10,0" VerticalAlignment="Center">
                                                    <TextBlock Text=".................................................................................." FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtMahalle}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtMahalle" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>

                                                <TextBlock Grid.Column="2" Text="Mahalle tanıtım kodu: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="3" Margin="2,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text=".................................................................................." FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtMahalleKodu}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtMahalleKodu" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Satır 4: Cadde Adı -->
                                            <Grid Grid.Row="3" Margin="0,12,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Cadde/Sokak/Bulvar/Meydan/Küme adı: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1" Margin="2,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="................................................................................................................................................................................................................................" FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtCaddeSokak}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtCaddeSokak" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Satır 5: Cadde Kodu / Kapı No -->
                                            <Grid Grid.Row="4" Margin="0,12,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Cadde/Sokak/Bulvar/Meydan tanıtım kodu: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1" Margin="2,0,10,0" VerticalAlignment="Center">
                                                    <TextBlock Text=".................................................................................." FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtCaddeKodu}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtCaddeKodu" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>

                                                <TextBlock Grid.Column="2" Text="Dış kapı no: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="3" Margin="2,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text=".................................................................................." FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtDisKapiNo}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtDisKapiNo" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Satır 6: Site Adı -->
                                            <Grid Grid.Row="5" Margin="0,12,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Site adı: " FontSize="8" FontWeight="Bold" Foreground="#000080" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1" Margin="2,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="................................................................................................................................................................................................................................" FontSize="8" VerticalAlignment="Center" Foreground="Black">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=txtSiteAdi}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="txtSiteAdi" FontSize="8" BorderThickness="0" Background="Transparent" Padding="0,1,0,0" Margin="0,1,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>
                                        </Grid>

                                        <!-- Alt Tablo (Pafta, Ada, vb.) -->
                                        <Border Grid.Row="4" BorderBrush="Black" BorderThickness="1">
                                            <UniformGrid Columns="6" Rows="2">
                                                <!-- Başlıklar -->
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,1" Background="#F4F4F4" Padding="2">
                                                    <TextBlock Text="3. Pafta no." FontSize="7" FontWeight="Bold" Foreground="#000080" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,1" Background="#F4F4F4" Padding="2">
                                                    <TextBlock Text="4. Ada no." FontSize="7" FontWeight="Bold" Foreground="#000080" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,1" Background="#F4F4F4" Padding="2">
                                                    <TextBlock Text="5. Parsel no." FontSize="7" FontWeight="Bold" Foreground="#000080" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,1" Background="#F4F4F4" Padding="2">
                                                    <TextBlock Text="6. Blok no." FontSize="7" FontWeight="Bold" Foreground="#000080" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,1" Background="#F4F4F4" Padding="2">
                                                    <TextBlock Text="7. Bağımsız&#x0a;bölüm no." TextAlignment="Center" FontSize="6" FontWeight="Bold" Foreground="#000080" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,0,1" Background="#F4F4F4" Padding="2">
                                                    <TextBlock Text="8. Yapı Kimlik No" FontSize="7" FontWeight="Bold" Foreground="#000080" HorizontalAlignment="Center"/>
                                                </Border>

                                                <!-- Değerler -->
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,0" Padding="2">
                                                    <TextBlock x:Name="vPafta" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,0" Padding="2">
                                                    <TextBlock x:Name="vAda" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,0" Padding="2">
                                                    <TextBlock x:Name="vParsel" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,0" Padding="2">
                                                    <TextBlock x:Name="vBlok" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8"/>
                                                </Border>
                                                <Border BorderBrush="Black" BorderThickness="0,0,1,0" Padding="2">
                                                    <TextBlock x:Name="vBagBol" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8"/>
                                                </Border>
                                                <Border BorderBrush="Transparent" BorderThickness="0" Padding="2">
                                                    <TextBlock x:Name="vYKN" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8"/>
                                                </Border>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- PANEL 2 -->
                                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1,2,2,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,0" Padding="3">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="9. Ruhsatın veriliş amacı" FontWeight="Bold" FontSize="8" Margin="0,0,0,2"/>
                                                <UniformGrid Grid.Row="1" Columns="2">
                                                    <CheckBox Content="1.Yeni yapı" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="10.Restorasyon" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="2.Yenileme" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="11.Güçlendirme" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="3.Yeniden" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="12.Kullanım değ(ş)" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="4.Ek Bina" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="13.Fosseptik" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="5.Kat ilavesi" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="14.Mekanik tesisat" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="6.İlave" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="15.Elektrik tesisat" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="7. İksaa" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="16.İsim değ(işk)" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="8.Tadilat" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="17.İstinat duvarı" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="9.Dolgu" FontSize="7" Margin="1"/>
                                                    <CheckBox Content="18.Bahçe duvarı" FontSize="7" Margin="1"/>
                                                </UniformGrid>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Satır 1 -->
                                            <Border Grid.Row="0" Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                <StackPanel>
                                                    <TextBlock Text="10. Ruhsatın onay tarihi" FontSize="7" FontWeight="Bold"/>
                                                    <TextBlock Text="___/___/20__" FontSize="7" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                <StackPanel>
                                                    <TextBlock Text="11. Ruhsat no." FontSize="7" FontWeight="Bold"/>
                                                    <TextBlock x:Name="val11" Text="-" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="0" Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                <StackPanel>
                                                    <TextBlock Text="12. İlk ruhsat tarihi" FontSize="7" FontWeight="Bold"/>
                                                    <TextBlock Text="___/___/____" FontSize="7" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="0" Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,0,1" Padding="2">
                                                <StackPanel>
                                                    <TextBlock Text="13. İlk ruhsat no." FontSize="7" FontWeight="Bold"/>
                                                    <TextBlock x:Name="val13" Text="-" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Satır 2 -->
                                            <Border Grid.Row="1" Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                <StackPanel>
