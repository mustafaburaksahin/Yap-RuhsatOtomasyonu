<Page x:Class="YapıRuhsatOtomasyonu.SicilBilgileri.SicilPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      d:DesignHeight="850" d:DesignWidth="1300" Background="White" Title="Siciller">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox x:Name="Panel1" Grid.Column="0" Width="420" Header="Sicil Detayları" Background="#F5F5F5" Margin="0,0,10,0" BorderBrush="#D0D0D0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="135"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="1" Text="Sicil Tipi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <ComboBox x:Name="cmbSicilTipi" Grid.Row="1" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="2" Text="TC Kimlik No:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtTcKimlikNo" Grid.Row="2" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="3" Text="Vergi No:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtVergiNo" Grid.Row="3" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="4" Text="Firma Adı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtFirmaAdi" Grid.Row="4" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="5" Text="Ad Soyad:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtAdSoyad" Grid.Row="5" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="6" Text="Doğum Yeri:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDogumYeri" Grid.Row="6" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="7" Text="Doğum Tarihi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <DatePicker x:Name="dpDogumTarihi" Grid.Row="7" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="8" Text="Vergi Dairesi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtVergiDairesi" Grid.Row="8" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="9" Text="Anne Adı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtAnneAdi" Grid.Row="9" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="10" Text="Baba Adı:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtBabaAdi" Grid.Row="10" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="11" Text="Telefon NO:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtTelefonNo" Grid.Row="11" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="12" Text="Email:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtEmail" Grid.Row="12" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="13" Text="Alan Kişi:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtAlanKisi" Grid.Row="13" Grid.Column="1" Background="White" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="14" Text="Adres:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,8"/>
                    <TextBox x:Name="txtAdres" Grid.Row="14" Grid.Column="1" Height="60" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="15" Text="Açıklama:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,8,8"/>
                    <TextBox x:Name="txtAciklama" Grid.Row="15" Grid.Column="1" Height="60" Background="White" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="16" Text="Diğer Bilgiler:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,15"/>
                    <TextBox x:Name="txtDigerBilgiler" Grid.Row="16" Grid.Column="1" Height="60" Background="White" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Grid.Row="17" Text="Kaydeden Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtKaydeden" Grid.Row="17" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="18" Text="Kayıt Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtKayitTarihi" Grid.Row="18" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="19" Text="Değiştiren Kullanıcı:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistiren" Grid.Row="19" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>

                    <TextBlock Grid.Row="20" Text="Değiştirme Tarihi:" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,8"/>
                    <TextBox x:Name="txtDegistirmeTarihi" Grid.Row="20" Grid.Column="1" IsReadOnly="True" Background="#E0E0E0" Margin="0,0,0,8" Padding="5"/>
                </Grid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Siciller" BorderBrush="#D0D0D0" Margin="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="dgSiciller"
                  SelectionChanged="dgSiciller_SelectionChanged"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  CanUserAddRows="False"
                  CanUserReorderColumns="False" 
                  CanUserResizeColumns="True"   
                  Background="White" 
                  AlternatingRowBackground="#FAFAFA"
                  GridLinesVisibility="All" 
                  HorizontalGridLinesBrush="#E0E0E0" 
                  VerticalGridLinesBrush="#E0E0E0"
                  RowHeight="35" 
                  ColumnWidth="Auto" 
                  MinColumnWidth="90" 
                  HorizontalScrollBarVisibility="Visible" 
                  VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>

                        <DataGridTextColumn Binding="{Binding SiraNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="ID" FontWeight="Bold"/>
                                        <TextBox Width="50" TextChanged="FilterTextBox_TextChanged" Tag="SiraNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding SicilTipi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Sicil Tipi" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="SicilTipi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding TcKimlikNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="TC Kimlik No" FontWeight="Bold"/>
                                        <TextBox Width="110" TextChanged="FilterTextBox_TextChanged" Tag="TcKimlikNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding VergiNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Vergi No" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="VergiNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding FirmaAdi}" Width="150">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Firma Adı" FontWeight="Bold"/>
                                        <TextBox Width="130" TextChanged="FilterTextBox_TextChanged" Tag="FirmaAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding AdSoyad}" Width="150">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Ad Soyad" FontWeight="Bold"/>
                                        <TextBox Width="130" TextChanged="FilterTextBox_TextChanged" Tag="AdSoyad" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding DogumYeri}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Doğum Yeri" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="DogumYeri" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding DogumTarihi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Doğum Tarihi" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="DogumTarihi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding VergiDairesi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Vergi Dairesi" FontWeight="Bold"/>
                                        <TextBox Width="120" TextChanged="FilterTextBox_TextChanged" Tag="VergiDairesi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding AnneAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Anne Adı" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="AnneAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding BabaAdi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Baba Adı" FontWeight="Bold"/>
                                        <TextBox Width="100" TextChanged="FilterTextBox_TextChanged" Tag="BabaAdi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding TelefonNo}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Telefon NO" FontWeight="Bold"/>
                                        <TextBox Width="110" TextChanged="FilterTextBox_TextChanged" Tag="TelefonNo" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding Email}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Email" FontWeight="Bold"/>
                                        <TextBox Width="130" TextChanged="FilterTextBox_TextChanged" Tag="Email" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding AlanKisi}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Alan Kişi" FontWeight="Bold"/>
                                        <TextBox Width="120" TextChanged="FilterTextBox_TextChanged" Tag="AlanKisi" materialDesign:HintAssist.Hint="Filtrele..."/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Page>