<Window x:Class="YapıRuhsatOtomasyonu.Login.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Giriş Yap" Height="550" Width="400" 
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Grid>
        <!-- Ana Kart Yapısı -->
        <materialDesign:Card UniformCornerRadius="20" Margin="20" Padding="10" VerticalAlignment="Center" Background="White">
            <StackPanel Margin="20">

                <!-- Üst İkon / Logo Alanı -->
                <Border Width="100" Height="100" CornerRadius="50" Background="#F0F0F0" BorderBrush="#C0C0C0" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border.Clip>
                        <RectangleGeometry RadiusX="50" RadiusY="50" Rect="0,0,100,100"/>
                    </Border.Clip>
                    <!-- Logo buraya gelecek (HighQuality eklendi) -->
                    <!-- Düzeltilmiş Hali: Background özelliği silindi -->
                    <Image x:Name="imgLoginLogo" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Başlık (C# tarafında erişmek için x:Name eklendi) -->
                <TextBlock x:Name="txtLoginBaslik" Text="YAPI RUHSAT OTOMASYONU" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,20" TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Kullanıcı Adı -->
                <TextBox x:Name="txtKullanici" 
                         materialDesign:HintAssist.Hint="Kullanıcı Adı" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,10" FontSize="14"/>

                <!-- Şifre -->
                <PasswordBox x:Name="txtSifre" 
                             materialDesign:HintAssist.Hint="Şifre" 
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             Margin="0,10" FontSize="14"/>

                <!-- Giriş Butonu -->
                <Button x:Name="BtnGiris" 
                        Content="GİRİŞ YAP" 
                        Click="btnGiris_Click"
                        Margin="0,30,0,10" Height="45"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                <!-- Kapat Butonu -->
                <Button Content="Kapat" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="Red" 
                        Click="btnKapat_Click"
                        Margin="0,5"/>

                <!-- Alt Bilgi -->
                <TextBlock Text="© 2026 Belediye Otomasyonu" FontSize="10"
                           HorizontalAlignment="Center" Opacity="0.5" Margin="0,10,0,0"/>

            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>