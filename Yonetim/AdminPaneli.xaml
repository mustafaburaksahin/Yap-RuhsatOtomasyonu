<Page x:Class="YapıRuhsatOtomasyonu.Yonetim.AdminPaneli"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Gelişmiş Yetki Yönetimi" Background="#F5F6FA">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" UniformCornerRadius="12" Margin="0,0,10,0" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#673AB7" Padding="15" CornerRadius="12,12,0,0">
                    <TextBlock Text="Kullanıcı Seçin" Foreground="White" FontWeight="Bold" FontSize="16"/>
                </Border>

                <Border Grid.Row="1" Padding="10" Background="#F8F9FF" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                    <TextBox x:Name="txtKullaniciAra" 
                             materialDesign:HintAssist.Hint="İsim veya TC No ile ara..." 
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             TextChanged="txtKullaniciAra_TextChanged"
                             FontSize="13"/>
                </Border>

                <ListBox x:Name="lstKullanicilar" 
                         Grid.Row="2" 
                         SelectionChanged="lstKullanicilar_SelectionChanged" 
                         Background="White" 
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="2,4">
                                <Grid Margin="5,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Kind="Account" 
                                                             Foreground="#3F51B5" 
                                                             Width="28" Height="28" 
                                                             VerticalAlignment="Center" 
                                                             Margin="0,0,12,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AdSoyad}" 
                                                   FontWeight="Bold" 
                                                   FontSize="14" 
                                                   Margin="0,0,0,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#212121"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding KullaniciTipi}" Value="Admin">
                                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding KullaniciTipi}" Value="User">
                                                            <Setter Property="Foreground" Value="#008B8B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="TC: " 
                                                       FontSize="11" 
                                                       Foreground="Gray"/>
                                            <TextBlock Text="{Binding TcKimlikNo}" 
                                                       FontSize="11" 
                                                       Foreground="Gray" 
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" UniformCornerRadius="12" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#6200EE" Padding="15" CornerRadius="12,12,0,0">
                    <Grid>
                        <TextBlock Text="Modül ve Panel Yetki Atamaları" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="Görüntüle" Width="75" Foreground="White" FontSize="13" FontWeight="Bold" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Ekle" Width="60" Foreground="White" FontSize="13" FontWeight="Bold" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Sil" Width="55" Foreground="White" FontSize="13" FontWeight="Bold" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Güncelle" Width="75" Foreground="White" FontSize="13" FontWeight="Bold" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl x:Name="icYetkiler">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander HorizontalAlignment="Stretch" Margin="0,5" 
                                          Background="#F8F9FF" IsExpanded="True"
                                          BorderBrush="#DDD" BorderThickness="1">
                                    <Expander.Header>
                                        <Grid HorizontalAlignment="{Binding Path=HorizontalAlignment, RelativeSource={RelativeSource AncestorType=ContentPresenter}, Mode=OneWay}" 
                                              Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=ContentPresenter}, Mode=OneWay}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ViewModule" Foreground="#6200EE" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModulAdi}" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" FontSize="14"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,35,0">
                                                <Button Content="Tüm Yetkileri Ver" 
                                                        Click="BtnTumYetkileriVer_Click"
                                                        Tag="{Binding}"
                                                        Height="24" Padding="8,0" Margin="0,0,5,0"
                                                        FontSize="10" FontWeight="Bold"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Background="#E8EAF6" Foreground="#3F51B5"/>

                                                <Button Content="Tüm Yetkileri Kaldır" 
                                                        Click="BtnTumYetkileriKaldir_Click"
                                                        Tag="{Binding}"
                                                        Height="24" Padding="8,0"
                                                        FontSize="10" FontWeight="Bold"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Background="#FFEBEE" Foreground="#D32F2F"/>
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>

                                    <ItemsControl ItemsSource="{Binding Paneller}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="15,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="FileDocumentOutline" Foreground="Gray" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Panel}" Margin="10,0" VerticalAlignment="Center" Foreground="#333" FontSize="13"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" 
                                                                          IsChecked="{Binding YetkiVerildiMi}" 
                                                                          Unchecked="Görüntüle_Unchecked"
                                                                          Checked="Görüntüle_Checked"
                                                                          Width="75" Margin="0,0,10,0" Background="#4CAF50"/>

                                                            <StackPanel Orientation="Horizontal">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Panel}" Value="Admin Paneli">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Panel}" Value="Program Ayarları">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Panel}" Value="Kullanıcılar">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>

                                                                <ToggleButton Style="{StaticResource MaterialDesignSwitchLightToggleButton}" 
                                                                              IsChecked="{Binding EkleYetki}" 
                                                                              Checked="Islem_Checked"
                                                                              Width="60" Margin="0,0,10,0"/>

                                                                <ToggleButton Style="{StaticResource MaterialDesignSwitchLightToggleButton}" 
                                                                              IsChecked="{Binding SilYetki}" 
                                                                              Checked="Islem_Checked"
                                                                              Width="55" Margin="0,0,10,0"/>

                                                                <ToggleButton Style="{StaticResource MaterialDesignSwitchLightToggleButton}" 
                                                                              IsChecked="{Binding GuncelleYetki}" 
                                                                              Checked="Islem_Checked"
                                                                              Width="75"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2" Content="DEĞİŞİKLİKLERİ SİSTEME UYGULA VE KAYDET" 
                        Height="50" Margin="15" 
                        Click="BtnYetkiKaydet_Click"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#4CAF50" BorderThickness="0" FontSize="14" FontWeight="Bold"/>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>