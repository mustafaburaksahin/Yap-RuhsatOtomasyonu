<Page x:Class="YapıRuhsatOtomasyonu.Yonetim.Program"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Program Ayarları" Background="#F5F6FA">

    <Grid Margin="30">
        <!-- Sayfa içeriğini ortalamak ve daraltmak için MaxWidth verdik -->
        <StackPanel MaxWidth="600" HorizontalAlignment="Center">

            <TextBlock Text="Genel Sistem Ayarları" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

            <!-- 1. KART: Sistem ve Kurum Bilgileri -->
            <materialDesign:Card Padding="20" Margin="0,0,0,20" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Kurum Bilgileri" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,15"/>

                    <TextBox x:Name="txtSistemAdi" 
                             materialDesign:HintAssist.Hint="Sistem Adı (Uygulama Başlığı)" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" LostFocus="TextBox_BoslukTemizle"
                             Margin="0,0,0,15" FontSize="14"/>

                    <TextBox x:Name="txtBelediyeAdi" 
                             materialDesign:HintAssist.Hint="Belediye Adı (Örn: Develi Belediyesi)" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" LostFocus="TextBox_BoslukTemizle"
                             Margin="0,0,0,15" FontSize="14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtIl" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="İl (Örn: Kayseri)" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" LostFocus="TextBox_BoslukTemizle"/>

                        <TextBox x:Name="txtIlce" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="İlçe (Örn: Develi)" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" LostFocus="TextBox_BoslukTemizle"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- 2. KART: Logo Ayarları -->
            <materialDesign:Card Padding="20" UniformCornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo Önizleme Alanı -->
                    <Border Grid.Column="0" Width="120" Height="120" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Margin="0,0,20,0">
                        <Grid>
                            <TextBlock Text="Logo Yok" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#95A5A6"/>
                            <Image x:Name="imgLogoOnizleme" Stretch="Uniform" Margin="5"/>
                        </Grid>
                    </Border>

                    <!-- Logo Seçme İşlemleri -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Belediye Logosu" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,10"/>
                        <TextBlock Text="Ruhsat PDF çıktılarında ve sayfa üstbilgilerinde kullanılacak olan resmi logoyu seçin. (Sadece PNG veya JPG)" 
                                   TextWrapping="Wrap" Foreground="#7F8C8D" FontSize="12" Margin="0,0,0,15"/>

                        <Button x:Name="BtnLogoSec" Click="BtnLogoSec_Click" Width="150" HorizontalAlignment="Left"
                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                Content="LOGOYU DEĞİŞTİR" Foreground="#1976D2" BorderBrush="#1976D2"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- Kaydet Butonu -->
            <Button x:Name="BtnAyarlariKaydet" Click="BtnAyarlariKaydet_Click" Margin="0,30,0,0" Height="45"
                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#2E7D32" BorderBrush="#2E7D32"
                    materialDesign:ButtonAssist.CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20" Margin="0,0,8,0"/>
                    <TextBlock Text="AYARLARI KAYDET" FontSize="15" FontWeight="Bold"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</Page>